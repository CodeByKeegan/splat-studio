{
  "name": "splat-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "GUI for @playcanvas/splat-transform: SOG bundling, splat format conversion and collision generation, with a PlayCanvas viewer that overlays the collision mesh as a wireframe on the gaussian splat",
  "author": "CodeByKeegan",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,magenta \"node server/index.mjs\" \"vite\"",
    "build": "tsc --noEmit && vite build",
    "start": "node server/index.mjs",
    "demo": "node scripts/make-test-splat.mjs",
    "test": "node tests/e2e.mjs",
    "typecheck": "tsc --noEmit",
    "make-icon": "node scripts/make-icon.mjs",
    "fetch-node": "node scripts/fetch-node.mjs",
    "docs:capture": "node scripts/make-test-splat.mjs && npm run build && electron scripts/capture-docs.mjs",
    "electron": "electron .",
    "prepack:win": "npm run fetch-node && npm run build",
    "pack:dir": "npm run prepack:win && electron-builder --dir --win",
    "dist:win": "npm run prepack:win && electron-builder --win"
  },
  "dependencies": {
    "@playcanvas/splat-transform": "^2.5.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "playcanvas": "^2.19.6",
    "png-to-ico": "^2.1.8",
    "pngjs": "^7.0.0",
    "rcedit": "^4.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.codebykeegan.splatstudio",
    "productName": "Splat Studio",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "vendor/node/node.exe", "to": "node.exe" }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "CodeByKeegan",
        "repo": "splat-studio",
        "releaseType": "release"
      }
    ],
    "afterPack": "electron/afterPack.cjs",
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Splat Studio"
    },
    "portable": {
      "artifactName": "SplatStudio-${version}-portable.exe"
    }
  }
}
